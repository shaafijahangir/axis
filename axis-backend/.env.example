# Copy this file to .env and fill in the secrets.
# Defaults below match the docker-compose.yml infra (`pnpm infra:up`),
# so a fresh clone should work after you set JWT_SECRET + optional API keys.

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3002
API_PREFIX=api
FRONTEND_URL=http://localhost:3001

# ─── Database (docker-compose Postgres on host port 5433) ──────────────────
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5433
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=axis
DATABASE_SCHEMA=public

# ─── Auth / JWT ──────────────────────────────────────────────────────────────
# Generate a real secret: openssl rand -hex 48
# Production REFUSES to boot with this placeholder value.
JWT_SECRET=replace-me-openssl-rand-hex-48
JWT_EXPIRATION=7d

# ─── AI ──────────────────────────────────────────────────────────────────────
# Required for Study Coach / Feedback Copilot. Skip and AI features
# return graceful errors instead of crashing.
ANTHROPIC_API_KEY=
AI_DEFAULT_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=4096
AI_RATE_LIMIT_RPM=30
AI_RATE_LIMIT_TOKENS_DAY=500000

# ─── Redis (docker-compose) ──────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Email — Resend ──────────────────────────────────────────────────────────
# Get your key at: https://resend.com/api-keys
# Until your domain is verified at https://resend.com/domains, Resend only
# delivers to the Resend account owner email. Use onboarding@resend.dev
# as EMAIL_FROM in the meantime.
RESEND_API_KEY=
EMAIL_FROM=Axis <onboarding@resend.dev>
EMAIL_REPLY_TO=
EMAIL_ENABLED=true

# ─── Web Push — VAPID ────────────────────────────────────────────────────────
# Generate keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@axis.app

# ─── File Storage — S3-compatible ───────────────────────────────────────────
# Defaults target the local MinIO container (`pnpm infra:up`).
# For Cloudflare R2 in production, swap R2_ENDPOINT to the R2 account
# endpoint URL and use the R2 access/secret keys.
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=axisdev
R2_SECRET_ACCESS_KEY=axisdev123
R2_BUCKET=axis
R2_REGION=us-east-1
R2_PUBLIC_URL=http://localhost:9000/axis
R2_UPLOAD_URL_EXPIRY=900
R2_DOWNLOAD_URL_EXPIRY=3600

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3002/api/auth/google/callback

# ─── LTI 1.3 (optional — only for LMS integrations) ─────────────────────────
LTI_TOOL_URL=http://localhost:3002
LTI_TOOL_NAME=Axis
LTI_PRIVATE_KEY=
LTI_PUBLIC_KEY=
LTI_KEY_ID=axis-lti-key-1

# ─── Deployment (managed hosting, e.g. Render) ──────────────────────────────
# TLS for managed Postgres (Render/Neon/RDS require it). Off for local dev.
DATABASE_SSL=false
# Auth-cookie SameSite. Set to `none` ONLY when frontend and backend are on
# different registrable domains (e.g. *.onrender.com) — see auth.controller.ts.
# COOKIE_SAMESITE=none
