{
  "name": "axis",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "//": "── Dev workflow ───────────────────────────────────────────",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=axis-backend --filter=axis-frontend",
    "dev:phone": "turbo dev --filter=axis-backend --filter=axis-mobile",
    "dev:backend": "turbo dev --filter=axis-backend",
    "dev:frontend": "turbo dev --filter=axis-frontend",
    "dev:mobile": "turbo dev --filter=axis-mobile",
    "// 2": "── Infra (Postgres + Redis + MinIO via docker compose) ───",
    "infra:up": "docker compose up -d postgres redis minio minio-init",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f postgres redis minio",
    "infra:reset": "docker compose down -v && pnpm infra:up",
    "// 3": "── One-time onboarding ──────────────────────────────────",
    "setup": "pnpm install && pnpm infra:up && pnpm --filter axis-backend seed",
    "// 4": "── Quality gates ────────────────────────────────────────",
    "build": "turbo build",
    "build:backend": "turbo build --filter=axis-backend",
    "build:frontend": "turbo build --filter=axis-frontend",
    "lint": "turbo lint",
    "lint:backend": "turbo lint --filter=axis-backend",
    "lint:frontend": "turbo lint --filter=axis-frontend",
    "test": "turbo test",
    "test:backend": "turbo test --filter=axis-backend",
    "test:e2e": "turbo test:e2e --filter=axis-frontend",
    "typecheck": "turbo typecheck",
    "typecheck:backend": "turbo typecheck --filter=axis-backend",
    "typecheck:frontend": "turbo typecheck --filter=axis-frontend",
    "prepare": "husky"
  },
  "lint-staged": {
    "axis-backend/src/**/*.ts": [
      "prettier --write"
    ],
    "axis-frontend/src/**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "axis-mobile/**/*.{ts,tsx}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "wait-on": "^9.0.3"
  }
}
