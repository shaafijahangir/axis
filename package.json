{
  "name": "nexused",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:backend": "turbo dev --filter=nexused-backend",
    "dev:frontend": "turbo dev --filter=nexused-frontend",
    "dev:mobile": "turbo dev --filter=nexused-mobile",
    "build": "turbo build",
    "build:backend": "turbo build --filter=nexused-backend",
    "build:frontend": "turbo build --filter=nexused-frontend",
    "lint": "turbo lint",
    "lint:backend": "turbo lint --filter=nexused-backend",
    "lint:frontend": "turbo lint --filter=nexused-frontend",
    "test": "turbo test",
    "test:backend": "turbo test --filter=nexused-backend",
    "test:e2e": "turbo test:e2e --filter=nexused-frontend",
    "typecheck": "turbo typecheck",
    "typecheck:backend": "turbo typecheck --filter=nexused-backend",
    "typecheck:frontend": "turbo typecheck --filter=nexused-frontend",
    "prepare": "husky"
  },
  "lint-staged": {
    "nexused-backend/src/**/*.ts": [
      "prettier --write"
    ],
    "nexused-frontend/src/**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "nexused-mobile/**/*.{ts,tsx}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "wait-on": "^9.0.3"
  }
}
