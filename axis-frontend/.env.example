# Axis frontend environment variables.
# Copy to `.env.local` for development. Values prefixed NEXT_PUBLIC_ are inlined
# into the client bundle at build time — never put secrets behind that prefix.

# Base URL of the backend API, INCLUDING the `/api` path segment.
# The GraphQL endpoint is derived as `${NEXT_PUBLIC_API_URL}/graphql`.
# REQUIRED for production builds — `next build` fails fast if it is unset
# (see next.config.ts). Local dev falls back to http://localhost:3001.
NEXT_PUBLIC_API_URL=http://localhost:3002/api

# Default tenant id used to scope unauthenticated requests (e.g. registration).
NEXT_PUBLIC_DEFAULT_TENANT_ID=

# --- Sentry (optional) -------------------------------------------------------
# Source maps are only uploaded when SENTRY_AUTH_TOKEN is set; safe to leave
# blank in development.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
