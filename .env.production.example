# Production env template. Copy to .env.production and replace EVERY
# CHANGE_ME value. The backend refuses to boot in production if
# JWT_SECRET is missing, the example value, or shorter than 32 chars.

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3002
API_PREFIX=api

# Frontend origin allowed by CORS. MUST match the URL your users hit.
FRONTEND_URL=https://yourdomain.com

# ─── Database (internal compose name `postgres`) ─────────────────────────────
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USERNAME=axis
DATABASE_PASSWORD=CHANGE_ME_strong_password
DATABASE_NAME=axis
DATABASE_SCHEMA=public

# ─── Auth / JWT ──────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 48
# Production REFUSES to boot if this is empty, < 32 chars, or matches
# the known-insecure example.
JWT_SECRET=CHANGE_ME_at_least_64_chars_random_string
JWT_EXPIRATION=7d

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password

# ─── AI ──────────────────────────────────────────────────────────────────────
# Required for AI features (Study Coach, Feedback Copilot). The app
# returns graceful errors instead of crashing when these are missing.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=

# ─── Email — Resend ──────────────────────────────────────────────────────────
# Domain MUST be verified at https://resend.com/domains before you can
# send to anyone other than the Resend account owner. Until then leave
# EMAIL_FROM as `onboarding@resend.dev` (only delivers to your account
# email — fine for staging, not production).
RESEND_API_KEY=re_...
EMAIL_FROM=Axis <noreply@yourdomain.com>
EMAIL_REPLY_TO=support@yourdomain.com
EMAIL_ENABLED=true

# ─── Web Push — VAPID (generate: npx web-push generate-vapid-keys) ───────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@yourdomain.com

# ─── File Storage — Cloudflare R2 (or any S3-compatible) ────────────────────
# Get these from your Cloudflare R2 dashboard. Do NOT use the dev MinIO
# defaults in production.
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=axis
R2_REGION=auto
R2_PUBLIC_URL=https://pub-<hash>.r2.dev
R2_UPLOAD_URL_EXPIRY=900
R2_DOWNLOAD_URL_EXPIRY=3600

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://yourdomain.com/api/auth/google/callback

# ─── LTI 1.3 (optional — only if you integrate with another LMS) ────────────
LTI_TOOL_URL=https://yourdomain.com
LTI_TOOL_NAME=Axis
LTI_PRIVATE_KEY=
LTI_PUBLIC_KEY=
LTI_KEY_ID=axis-lti-key-1

# ─── Public URLs (used by nginx + frontend build) ───────────────────────────
API_PUBLIC_URL=https://yourdomain.com

# ─── Sentry Error Monitoring (optional — remove to disable) ─────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=axis

# ─── Internal token encryption (Sprint 6 Google Calendar — currently unused) ─
# 32-byte key for AES-256-GCM. Generate: openssl rand -hex 32
INTEGRATION_TOKEN_KEY=
