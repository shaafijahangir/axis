# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
API_PREFIX=api

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USERNAME=nexused
DATABASE_PASSWORD=CHANGE_ME_strong_password
DATABASE_NAME=nexused
DATABASE_SCHEMA=public

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_at_least_64_chars_random_string
JWT_EXPIRATION=7d

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password

# ── AI Services ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Frontend URL (CORS origin) ────────────────────────────────────────────────
FRONTEND_URL=https://yourdomain.com

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://yourdomain.com/api/auth/google/callback

# ── Cloudflare R2 / S3 Object Storage ─────────────────────────────────────────
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=nexused
R2_REGION=auto
R2_PUBLIC_URL=https://pub-<hash>.r2.dev
R2_UPLOAD_URL_EXPIRY=900
R2_DOWNLOAD_URL_EXPIRY=3600

# ── Email — Resend ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=NexusEd <noreply@yourdomain.com>
EMAIL_REPLY_TO=support@yourdomain.com
EMAIL_ENABLED=true

# ── Web Push — VAPID (generate: npx web-push generate-vapid-keys) ─────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@yourdomain.com

# ── Public URL (used by nginx and frontend build) ─────────────────────────────
API_PUBLIC_URL=https://yourdomain.com
